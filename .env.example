# Economic calendar provider
TE_API_KEY=YOUR_TRADING_ECONOMICS_API_KEY
TE_BASE_URL=https://api.tradingeconomics.com

# Trading and symbols
BROKER_TIMEZONE=UTC
UTC_OFFSET_HOURS=-5
SYMBOL=EURUSD
EVENT_MIN_IMPORTANCE=2
EVENT_INCLUDE_KEYWORDS=
EVENT_EXCLUDE_KEYWORDS=
ORDER_VOLUME=0.10
MAX_SPREAD_POINTS=25
STOP_LOSS_PIPS=12
TAKE_PROFIT_PIPS=24
TRAILING_STOP_PIPS=8
SECONDS_BEFORE_EVENT=10
DECISION_THRESHOLD=0.60
NO_TRADE_BAND=0.05
PAPER_TRADING=true
MAX_OPEN_POSITIONS=1
LIVE_CALENDAR_REFRESH_SECONDS=120
LIVE_LOOP_SLEEP_SECONDS=1
EVENTLESS_EVAL_SECONDS=20
LIVE_ACTIVITY_CSV=data/live_activity.csv

# Strategy options: default | zscore | momentum | donchian | donchian_nylondon | ema_rsi_trend | agentic_hybrid
STRATEGY=default
Z_SCORE_LOOKBACK_SECONDS=300
Z_SCORE_THRESHOLD=0.7
Z_WEIGHT=1.0
Z_COMBINATION_MODE=weighted
MOMENTUM_LOOKBACK_SECONDS=300
MOMENTUM_THRESHOLD=0.0005
MOMENTUM_WEIGHT=1.0
MOMENTUM_MODE=weighted
DONCHIAN_LOOKBACK_SECONDS=600
DONCHIAN_BREAKOUT_BUFFER_PIPS=0.2
DONCHIAN_MIN_CHANNEL_PIPS=1.0
DONCHIAN_CONFIRM_TICKS=1
DONCHIAN_TRIGGER_QUANTILE=0.80
DONCHIAN_SESSION_FILTER=false
DONCHIAN_SESSIONS=london,ny
EMA_FAST_SPAN=21
EMA_SLOW_SPAN=55
EMA_RSI_PERIOD=14
EMA_RSI_BUY_LEVEL=56
EMA_RSI_SELL_LEVEL=44
EMA_MIN_SEPARATION_PIPS=0.20
EMA_MOMENTUM_LOOKBACK_TICKS=20
EMA_MIN_MOMENTUM_PIPS=0.25
EMA_VOL_PERIOD=40
EMA_MIN_VOL_PIPS=0.05
AGENTIC_LEARNING_RATE=0.20
AGENTIC_EXPLORE_PROB=0.10
AGENTIC_MIN_CONFIDENCE=0.56
AGENTIC_REWARD_HORIZON_SECONDS=45
AGENTIC_REWARD_TARGET_PIPS=1.20
AGENTIC_STATE_PATH=models/agentic_state.json

# Model and files
DATA_DIR=data
MODEL_DIR=models
EVENTS_CSV=data/events.csv
MARKET_CSV=data/market_ticks.csv
TRAIN_WINDOW_DAYS=180
LOOKBACK_SECONDS=300
DIRECTION_LABEL_MODE=quantile_monthly
STRICT_MONTHLY_VALIDATION=false
LONG_HISTORY_MONTHS=12
SYNTHETIC_EVENT_INTERVAL_HOURS=6

# MT5 terminal credentials
MT5_LOGIN=0
MT5_PASSWORD=your_password
MT5_SERVER=your_broker_server
